#!/bin/bash
set -euo pipefail

appvue='src/App.vue'

# Show current wsUrl lines for verification
grep -A3 'CHANGE THESE TWO' "$appvue"
printf \\n
read -rp "Press enter to continue..."

# -----------------------
# Production build: uncomment template, comment hardcoded
# -----------------------
sed -i -E '
  # Uncomment protocol line (remove leading // only)
  s|^//(\s*const protocol = window\.location\.protocol.*)|\1|
  # Uncomment wsUrl template line (remove leading // only)
  s|^//(\s*const wsUrl = `\$\{protocol\}//\$\{window\.location\.host\}/ws`.*)|\1|
  # Comment hardcoded wsUrl line (prefix with //, keep indentation)
  s|^(\s*const wsUrl = .ws://192.*)|//\1|
' "$appvue"

grep -A3 'CHANGE THESE TWO' "$appvue"
printf \\n
read -rp "Press enter to run npm build"

# -----------------------
# Build & commit
# -----------------------
sudo npm run build

# -----------------------
# Revert: comment template, uncomment hardcoded
# -----------------------
sed -i -E '
  # Comment protocol line
  s|^(\s*const protocol = window\.location\.protocol.*)|//\1|
  # Comment wsUrl template line
  s|^(\s*const wsUrl = `\$\{protocol\}//\$\{window\.location\.host\}/ws`.*)|//\1|
  # Uncomment hardcoded wsUrl line
  s|^//(\s*const wsUrl = .ws://192.*)|\1|
' "$appvue"

grep -A3 'CHANGE THESE TWO' "$appvue"
printf \\n
read -rp "Press enter to commit and push"

git commit -m "building production $(date)" -a
git push

exit 0





