<template>
  <div>
    <!-- Desktop version -->
    <span class="desktop">
      <strong :class="colorClass">
        <span class="notes">♪ ♫</span>
        {{ stateText }}
        <span class="notes">♫ ♪</span>&nbsp;&nbsp;
      </strong>
      <a class="pauseicon" href="#" @click.prevent="$emit('action', 'toggle_playback')">
        <span :class="altClass">{{ toggleIcon }}</span>
      </a>&nbsp;
      <a :class="colorClass" href="#" @click.prevent="$emit('action', 'playlist_current')" 
         title="Playlist|current song">#{{ status.player.song_position || '?' }}/{{ status.player.song_length || '?' }}</a> &nbsp;
      <a class="skipend" href="#" @click.prevent="$emit('action', 'next_track')">▶▮</a>
    </span>

    <!-- Mobile version -->
    <span class="mobile">
      <strong :class="colorClass">
        <span class="notes">♪ ♫</span>
        {{ stateText }}
        <span class="notes"> ♫ ♪ </span>&nbsp;
      </strong>
      <a class="pauseicon" href="#" @click.prevent="$emit('action', 'toggle_playback')">
        <span :class="altClass">&nbsp;{{ toggleIcon }}</span>
      </a> &nbsp;&nbsp;&nbsp;
      <a :class="colorClass" href="#" @click.prevent="$emit('action', 'playlist_current')" 
         title="Playlist|current song">#{{ status.player.song_position || '?' }}/{{ status.player.song_length || '?' }}</a>
      &nbsp;&nbsp;
      <a class="skipend" href="#" @click.prevent="$emit('action', 'next_track')">
        <span class="ts">▶</span>
      </a>
    </span>
    <br>

    <!-- Progress bar and timer -->
    <span class="time" id="current_track">
      <a href="#" @click.prevent="$emit('action', 'reset_track')" title="Restart track">
        elapsed <span id="elapsed_display">{{ elapsedDisplay }}</span>/<span id="total_display">{{ totalDisplay }}</span> 
        (<span id="percent_display">{{ percentDisplay }}</span>%)
      </a>
      <br>
      <progress id="track_progress" :value="percentValue" max="100"></progress>
    </span>
    <br>

    <!-- Track info -->
    <strong class="song">
      <a class="hidden-link" :href="`https://musicbrainz.org/mbid/${current.musicbrainz_releasetrackid}`" target="_blank">
        ({{ disc }}-{{ track }}) {{ current.title }}
      </a>
    </strong>
    <br>

    <!-- Artist -->
    <span class="artist">
      <strong>
        <a :href="`https://musicbrainz.org/artist/${current.musicbrainz_artistid}`" target="_blank">
          {{ current.artist }}
        </a>
      </strong>
    </span>
    <br>

    <!-- Album -->
    <span class="album">
      <strong>
        <a :href="`https://musicbrainz.org/release/${current.musicbrainz_albumid}`" target="_blank">
          {{ albumDisplay }}&nbsp
        </a>
        <a href="#" @click.prevent="$emit('action', 'playlist_album')" title="Playlist|album">
          <i class="bi bi-box-arrow-up-right extlink"></i>
        </a>
      </strong>
    </span>
    <br>

    <!-- Status line - Desktop -->
    <span class="album desktop" style="font-style:normal">
      <a href="#" @click.prevent="$emit('action', 'mute_volume')">volume</a>: {{ status.player.volume }}%
      <span>
        <a href="#"
           class="repeat-toggle"
           :class="{ active: status.player.repeat }"
           @click.prevent="$emit('action', 'toggle_repeat')">⟳ </a>
      </span>
      <span v-if="status.player.single">single: <span class="smallemoji desktop">{{ singleIcon }}&nbsp;</span></span>
      <a href="#" @click.prevent="$emit('action', status.player.random ? 'disable_random' : 'enable_random')">random:</a>
      <span class="smallemoji desktop">{{ randomIcon }} &nbsp;</span>

<!--      <a v-if="status.player.consume" href="#" @click.prevent="$emit('action', 'disable_consume')">consume:</a>&nbsp;
      <span v-if="status.player.consume" class="smallemoji desktop">{{ consumeIcon }} &nbsp;</span> -->

      <a href="#" @click.prevent="$emit('action', 'toggle_consume')">consume:</a> 
      <span class="smallemoji desktop">{{ consumeIcon }} &nbsp;</span> 

<!--			<span>single: <span class="smallemoji desktop">{{ singleIcon }}&nbsp;</span></span>
      <a href="#" @click.prevent="$emit('action', 'toggle_random')">random:</a>
      <span class="smallemoji desktop">{{ randomIcon }}&nbsp;</span>

-->
      <a href="#" @click.prevent="$emit('action', 'linger_next')">linger{{ lingerXY }}:</a>&nbsp;
      <span v-html="lingerStat"></span> &nbsp;
    </span>

    <!-- Status line - Mobile -->
    <span class="album mobile">
      <a href="#" @click.prevent="$emit('action', 'mute_volume')">vol.</a>: {{ status.player.volume }}%
      <span v-if="repeatIcon">{{ repeatIcon }}</span>
      <span v-if="status.player.single">single: {{ singleIcon }} &nbsp;</span>
      <a href="#" @click.prevent="$emit('action', status.player.random ? 'disable_random' : 'enable_random')">random</a>:
      <span class="smallemoji mobile">{{ randomIcon }}</span>
      <span v-if="status.player.consume"><br>consume: <span class="smallemoji mobile" style="font-style:normal">{{ consumeIcon }}</span></span>
      <br>&nbsp;<a href="#" @click.prevent="$emit('action', 'linger_next')">linger{{ lingerXY }}</a>: 
      <span v-html="lingerStatMobile"></span>
    </span>

    <br><hr>
  </div>
</template>

<script>
import { ref, computed, watch, onMounted, onUnmounted } from 'vue'

export default {
  name: 'CurrentlyPlaying',
  props: {
    status: Object,
    current: Object,
    next: Object,
    linger: Object
  },
  emits: ['action'],
  setup(props, { emit }) {
    const elapsed = ref(0)
    const timerInterval = ref(null)

    const stateText = computed(() => {
      return props.status?.player?.state === 'play' ? 'playing' : 'paused'
    })

    const colorClass = computed(() => {
      return props.status?.player?.state === 'play' ? 'playing' : 'artist'
    })

    const altClass = computed(() => {
      return props.status?.player?.state === 'play' ? 'artist' : 'playing'
    })

    const toggleIcon = computed(() => {
      return props.status?.player?.state === 'play' ? '▮▮' : '▶'
    })

    const disc = computed(() => {
      return String(props.current?.disc || '0').padStart(2, '0')
    })

    const track = computed(() => {
      return String(props.current?.track || '0').padStart(2, '0')
    })

    const albumDisplay = computed(() => {
      const album = props.current?.album || ''
      const year = props.current?.year?.split('-')[0] || ''
      return `${album.replace(' (mp3)', '')} ${year ? `(${year})` : ''}`
    })

//    const repeatIcon = computed(() => {
//      return props.status?.player?.repeat ? "<span class='playing'>⟳&nbsp;</span>" : ''
//    })

//    const repeatIcon = computed(() => {
//      return props.status?.player?.repeat ? '⟳ ' : '⟳ '
//    })

    const repeatIcon = computed(() => {
      return '⟳ '
    })


    const singleIcon = computed(() => {
      return props.status?.player?.single ? '✅' : ''
    })

    const randomIcon = computed(() => {
      return props.status?.player?.random ? ' ✅' : ' ❌'
    })

    const consumeIcon = computed(() => {
      return props.status?.player?.consume ? ' ✅' : ' ❌'
    })

    // Timer logic
    const sec2mmss = (s) => {
      const totalSec = Math.floor(s)
      const h = Math.floor(totalSec / 3600)
      const m = Math.floor((totalSec % 3600) / 60)
      const sec = totalSec % 60
      if (h > 0) {
        return `${h}:${m < 10 ? '0' : ''}${m}:${sec < 10 ? '0' : ''}${sec}`
      } else {
        return `${m}:${sec < 10 ? '0' : ''}${sec}`
      }
    }

    const elapsedDisplay = computed(() => {
      return sec2mmss(elapsed.value)
    })

    const totalDisplay = computed(() => {
      return sec2mmss(props.status?.player?.duration || 0)
    })

    const percentDisplay = computed(() => {
      const total = props.status?.player?.duration || 1
      return Math.floor((elapsed.value / total) * 100)
    })

    const percentValue = computed(() => {
      return percentDisplay.value
    })

    // Linger status
    const lingerXY = computed(() => {
      // TODO: Implement lingerXY logic when available
      return ''
    })

    const lingerStat = computed(() => {
      if (!props.linger) {
        return "<a class='smallemoji' href='#' @click.prevent=\"$emit('action', 'linger_start')\">❌</a>"
      }

      const count = props.linger.count || 0
      const limit = props.linger.limit || 0
      const paused = props.linger.paused

//      if (paused) {
//        return `<span class=artist><a class=pauseicon style="font-style:normal" href='#'>▮▮</a>&nbsp; #${count}/${limit}&nbsp;&nbsp;</span><a class="skipend" style="font-style:normal; color:#007bff;" href='#'>▶▮</a>`
//      } else {
//        return `<span class=playing style="font-style:normal"><a style="font-style:normal" href='#'>▶</a> #${count}/${limit}</span>&nbsp;&nbsp;<a class="skipend" style="font-style:normal; color:#007bff;" href='#'>▶▮</a>`
//      }

      if (paused) {
        return `<span class=artist>
                  <a class=pauseicon style="font-style:normal" href="#" @click.prevent="$emit('action', 'linger_toggle')">▮▮</a>&nbsp; #${count}/${limit}&nbsp;&nbsp;
                </span>
                <a class="skipend" style="font-style:normal; color:#007bff;" href="#" @click.prevent="$emit('action', 'linger_next')">▶▮</a>`
      } else {
        return `<span class=playing style="font-style:normal">
                  <a style="font-style:normal" href="#" @click.prevent="$emit('action', 'linger_toggle')">▶</a> #${count}/${limit}
                </span>&nbsp;&nbsp;
                <a class="skipend" style="font-style:normal; color:#007bff;" href="#" @click.prevent="$emit('action', 'linger_next')">▶▮</a>`
      }
    })



    const lingerStatMobile = computed(() => {
      if (!props.linger) {
        return '<span class="smallemoji mobile">❌</span>'
      }

      const count = props.linger.count || 0
      const limit = props.linger.limit || 0
      const paused = props.linger.paused

      if (paused) {
        return `<span class=artist><a href='#' class=pauseicon>▮▮</a>&nbsp;&nbsp;&nbsp;#${count}/${limit}</span>`
      } else {
        return `<span class=playing style="font-style:normal;color:green;"><a href="#">▶</a>&nbsp; #${count}/${limit}&nbsp;&nbsp;</span><a class="skipend" style="font-style:normal; color:#007bff;" href='#'>▶▮</a>`
      }
    })

    // Initialize elapsed time
    watch(() => props.status?.player?.elapsed, (newElapsed) => {
      if (newElapsed !== undefined) {
        elapsed.value = newElapsed
      }
    }, { immediate: true })

    // Start/stop timer based on play state
    watch(() => props.status?.player?.state, (newState) => {
      if (timerInterval.value) {
        clearInterval(timerInterval.value)
        timerInterval.value = null
      }

      if (newState === 'play') {
        timerInterval.value = setInterval(() => {
          const duration = props.status?.player?.duration || 0
          if (elapsed.value < duration) {
            elapsed.value++
          }
        }, 1000)
      }
    }, { immediate: true })

    onUnmounted(() => {
      if (timerInterval.value) {
        clearInterval(timerInterval.value)
      }
    })

    return {
      stateText,
      colorClass,
      altClass,
      toggleIcon,
      disc,
      track,
      albumDisplay,
      repeatIcon,
      singleIcon,
      randomIcon,
      consumeIcon,
      elapsedDisplay,
      totalDisplay,
      percentDisplay,
      percentValue,
      lingerXY,
      lingerStat,
      lingerStatMobile
    }
  }
}
</script>


<style scoped>
  a.repeat-toggle {
    font-style: normal;
    color: gray;
  }

  a.repeat-toggle.active {
    font-style: normaal;
    color: green;
  }
</style>
